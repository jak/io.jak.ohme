{
  "title": { "en": "Set target time" },
  "titleFormatted": { "en": "Set target time to [[hour]]:[[minute]]" },
  "platforms": ["local", "cloud"],
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=ohme-home-pro|ohme-epod|ohme-home|ohme-go"
    },
    {
      "type": "number",
      "name": "hour",
      "title": { "en": "Hour" },
      "min": 0,
      "max": 23,
      "step": 1
    },
    {
      "type": "number",
      "name": "minute",
      "title": { "en": "Minute" },
      "min": 0,
      "max": 59,
      "step": 1
    }
  ]
}
