{
  "name": {
    "en": "Ohme Home"
  },
  "class": "evcharger",
  "platforms": [
    "local"
  ],
  "connectivity": [
    "cloud"
  ],
  "capabilities": [
    "measure_power",
    "measure_voltage",
    "measure_current",
    "measure_battery",
    "meter_power",
    "evcharger_charging",
    "charger_status",
    "charge_mode",
    "target_percentage",
    "target_time",
    "preconditioning_duration",
    "lock_buttons",
    "price_cap_enabled"
  ],
  "images": {
    "small": "/drivers/ohme-home/assets/images/small.png",
    "large": "/drivers/ohme-home/assets/images/large.png",
    "xlarge": "/drivers/ohme-home/assets/images/xlarge.png"
  },
  "pair": [
    {
      "id": "login",
      "template": "login_credentials",
      "options": {
        "usernameLabel": {
          "en": "Ohme Email"
        },
        "title": {
          "en": "Sign in with your Ohme account"
        },
        "usernamePlaceholder": {
          "en": "you@example.com"
        },
        "passwordLabel": {
          "en": "Ohme Password"
        },
        "passwordPlaceholder": {
          "en": "Your Ohme app password"
        }
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      },
      "options": {
        "singular": true
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "energy": {
    "batteries": [
      "OTHER"
    ],
    "evCharger": true,
    "meterPowerImportedCapability": "meter_power"
  },
  "capabilitiesOptions": {
    "measure_battery": {
      "title": {
        "en": "Vehicle Battery"
      }
    }
  }
